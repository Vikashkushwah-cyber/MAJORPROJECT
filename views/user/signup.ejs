<% layout ("/layouts/boilerplate") %>

<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">

    <h2>Sign Up on Wanderlust</h2>
    <form method="POST" action="/users/signup" novalidate class="needs-validation">
       <div class="mb-3"> 
         <label for="email" class="form-label">Email</label>
        <input name="email" type="email" class="form-control" required>
        <div class="valid-feedback">Email looks good</div>
      </div>

        <div class="mb-3">
             <label for="username" class="form-label">Username</label>
             <input name="username" type="text" class="form-control" required >
             <div class="invalid-feedback">enter valid username </div>
        </div>

         <div class="mb-3">
             <label for="password" class="form-label">Password</label>
             <input name="password" type="password" class="form-control" required >
             <div class="invalid-feedback">enter valid password </div>
        </div>

        <button class="btn btn-dark edit-btn mt-3">Sign Up</button>
    </form>
       </div>  
    </div>     
</body>