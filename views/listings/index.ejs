<% layout("/layouts/boilerplate") %>

<body>
  
    <div id = "filters">
       <a href="/listings?category=Trending" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
          </div>
       </a>
       <a href="/listings?category=Rooms" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
          </div>
       </a>
       <a href="/listings?category=Iconic%20cities" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic cities</p> 
       </div>
       </a>
        <a href="/listings?category=Mountains" class="filter-link">
         <div class="filter">
          <div><i class="fa-solid fa-mountain"></i></div>
          <p>Mountains</p>
         </div>
        </a>
        <a href="/listings?category=Amazing%20pools" class="filter-link">
         <div class="filter">
          <div><i class="fa-solid fa-person-swimming"></i></div>
          <p>Amazing pools</p>
         </div>
        </a>
        <a href="/listings?category=Camping" class="filter-link">
         <div class="filter">
          <div><i class="fa-solid fa-campground"></i></div>
          <p>Camping</p>
         </div>
        </a>
        <a href="/listings?category=Lake" class="filter-link">
         <div class="filter">
          <div><i class="fa-solid fa-water"></i></div>
          <p>Lake</p>
         </div>
        </a>
        <a href="/listings?category=Islands" class="filter-link">
         <div class="filter">
          <div><i class="fa-solid fa-sailboat"></i></div>
          <p>Islands</p>
         </div>
        </a>
      
       
       <div class="tax-toggle">
        <div class="form-check form-switch form-check-reverse">
         <input class="form-check-input" type="checkbox" id="switchCheckReverse">
         <label class="form-check-label" for="switchCheckReverse">Display total after taxes</label>
       </div>
       </div>

    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1  ">
        <% for(let listing of allListings){ %>
            <a href="/listings/<%= listing.id %>" style="text-decoration: none;">
                <div class="card h-100 listing-card">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="Listing_image">
                    
                    <div class="card-body">
                         <h5 class="card-title"><%= listing.title %></h5>
                        <p class="card-text"><%= listing.description %></p>
                        <p>&#8377; <%= listing.price.toLocaleString("en-IN")%> /night<i class="taxInfo"> &nbsp; &nbsp; +18% GST</i></p>

                     </div>
                     
                </div>
            </a>
       
        
        <% } %>
    </div>
    
    <script>
       
    </script>
</body>
